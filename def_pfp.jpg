*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial;
}


body{
background:#000000;
display:none;
justify-content:center;
align-items:center;
height:100vh;
padding:15px;
overflow:hidden;
animation:bgFade 1s ease;
}

.box{
width:100%;
max-width:340px;
padding:25px;
border:2px solid #0080ff;
border-radius:25px;
background:#050505;
text-align:center;
animation:show .5s ease;
box-shadow:0 0 25px rgba(0,128,255,.25);
position:relative;
overflow:hidden;
}

.box::before{
content:"";
position:absolute;
top:-50%;
left:-50%;
width:200%;
height:200%;
background:linear-gradient(
45deg,
transparent,
rgba(0,128,255,.12),
transparent
);
animation:shine 5s linear infinite;
pointer-events:none;
}

@keyframes shine{

0%{
transform:rotate(0deg);
}

100%{
transform:rotate(360deg);
}

}

@keyframes bgFade{

from{
opacity:0;
}

to{
opacity:1;
}

}

@keyframes show{

from{
opacity:0;
transform:scale(.85) translateY(20px);
}

to{
opacity:1;
transform:scale(1) translateY(0);
}

}

.logo{
font-size:32px;
font-weight:bold;
color:#0080ff;
margin-bottom:20px;
letter-spacing:1px;
animation:logoPulse 2s infinite;
position:relative;
z-index:2;
}

@keyframes logoPulse{

0%{
transform:scale(1);
text-shadow:0 0 0px #0080ff;
}

50%{
transform:scale(1.05);
text-shadow:0 0 15px #0080ff;
}

100%{
transform:scale(1);
text-shadow:0 0 0px #0080ff;
}

}

.inputbox{
position:relative;
margin-top:15px;
animation:fadeUp .7s ease;
z-index:2;
}

input{
width:100%;
padding:14px;
background:#000000;
border:2px solid #0080ff;
border-radius:14px;
outline:none;
color:#fff;
font-size:15px;
transition:.25s;
}

input:focus{
box-shadow:0 0 15px rgba(0,128,255,.6);
transform:scale(1.02);
}

input:hover{
transform:scale(1.01);
}

.suffix{
position:absolute;
right:14px;
top:50%;
transform:translateY(-50%);
color:#777;
font-size:13px;
pointer-events:none;
}

.toggle{
position:absolute;
right:14px;
top:50%;
transform:translateY(-50%);
color:#0080ff;
font-size:13px;
cursor:pointer;
user-select:none;
font-weight:bold;
transition:.2s;
}

.toggle:hover{
transform:translateY(-50%) scale(1.1);
text-shadow:0 0 10px #0080ff;
}

button{
width:100%;
padding:14px;
margin-top:20px;
border:none;
border-radius:14px;
background:#0080ff;
color:#fff;
font-size:16px;
font-weight:bold;
cursor:pointer;
transition:.25s;
animation:fadeUp .9s ease;
position:relative;
z-index:2;
}

button:hover{
transform:scale(1.03);
box-shadow:0 0 20px rgba(0,128,255,.7);
}

button:active{
transform:scale(.97);
}

#msg{
margin-top:15px;
font-size:14px;
color:#fff;
word-break:break-word;
min-height:20px;
animation:fadeUp 1s ease;
position:relative;
z-index:2;
}

.loading{
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
background:#000;
display:flex;
justify-content:center;
align-items:center;
color:#0080ff;
font-size:18px;
font-weight:bold;
z-index:9999;
animation:pulse 1s infinite;
}

@keyframes pulse{

0%{
opacity:.5;
transform:scale(1);
}

50%{
opacity:1;
transform:scale(1.08);
}

100%{
opacity:.5;
transform:scale(1);
}

}

@keyframes fadeUp{

from{
opacity:0;
transform:translateY(20px);
}

to{
opacity:1;
transform:translateY(0);
}

}